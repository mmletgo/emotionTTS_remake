# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.pytest_cache/

# 运行时产物（本地生成、不入库）
webapp/config/config.json
outputs/*
!outputs/.gitkeep

# 用户角色素材库：完全是本地数据，仓库不追踪任何内容
characters/*
!characters/.gitkeep

# Whisper 模型：权重大文件不入库，配置和词表已入库
models/whisper-small/model.bin
models/whisper-small/*.safetensors
models/whisper-small/.cache/

# macOS / IDE
.DS_Store
.idea/
.vscode/
*.swp
